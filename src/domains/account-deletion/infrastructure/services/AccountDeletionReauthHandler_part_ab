    }

    // Delete account
    const result = await repository.deleteAccount(user);
    if (result.success) {
      return { success: true };
    }

    return {
      success: false,
      error: result.error,
      requiresReauth: false,
    };
  } catch (error: unknown) {
    return {
      success: false,
      error: {
        code: 'auth/failed',
        message: error instanceof Error ? error.message : 'Unknown error',
      },
      requiresReauth: false,
    };
  }
}
